{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "rootDir": "frontend/src",
    "outDir": "domain_interface_explorer/static/dist",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "verbatimModuleSyntax": true,
    "sourceMap": false,
    "declaration": false,
    "removeComments": true
  },
  "include": ["frontend/src/**/*.ts"]
}
